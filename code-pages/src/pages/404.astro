---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404: Pro Telemetry Offline">
	<main class="error-container">
		<h1>404</h1>
		<div class="accent-line"></div>
		<p>Runtime Error: Requested v1.5 Pro specification module could not be evaluated by the execution kernel.</p>
		
		<div class="button-group">
			<a href="/GameScript-v1.5-Pro/code-pages/" class="btn-primary">Return to Core Engine</a>
			<button onclick="LiveChatWidget.call('maximize')" class="btn-secondary">Contact Pro Support</button>
		</div>
	</main>
</Layout>

<style>
	.error-container {
		min-height: 100vh;
		display: flex;
		flex-direction: column;
		justify-content: center;
		align-items: center;
		color: #f9fafb;
		text-align: center;
		background: #030712;
		background-image: linear-gradient(to right, rgba(99, 102, 241, 0.15) 1px, transparent 1px);
		background-size: 40px 40px;
		font-family: system-ui, sans-serif;
	}
	h1 { font-size: 6rem; margin: 0; color: #f59e0b; }
	.accent-line { height: 4px; width: 60px; background: linear-gradient(90deg, #f59e0b, #ae4ef2); margin: 1rem 0; }
	p { color: #9ca3af; margin-bottom: 2rem; max-width: 450px; }
	.button-group { display: flex; gap: 1rem; }
	.btn-primary, .btn-secondary {
		color: #ffffff; background: #111827; border: 1px solid rgba(99, 102, 241, 0.3);
		padding: 0.75rem 1.5rem; border-radius: 8px; text-decoration: none; font-weight: 600; cursor: pointer;
	}
	.btn-primary:hover { border-color: #f59e0b; }
	.btn-secondary:hover { border-color: #ae4ef2; }
</style>
